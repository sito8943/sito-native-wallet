{
  "private": true,
  "name": "sito-wallet",
  "version": "0.2.0",
  "main": "expo-router/entry",
  "type": "module",
  "imports": {
    "#design/*": "./src/shared/design/*/index.ts",
    "#features/*": "./src/features/*/index.ts",
    "#shared/*": "./src/shared/*/index.ts",
    "#i18n/*": "./src/shared/i18n/*.ts"
  },
  "scripts": {
    "lint": "npm run lint-typecheck && npm run lint-eslint && npm run lint-prettier && npm run lint-knip",
    "lint:fix": "eslint --fix .",
    "lint-typecheck": "tsc --noEmit",
    "lint-eslint": "eslint .",
    "lint-prettier": "prettier --check .",
    "lint-knip": "knip",
    "prettier:format": "prettier --write .",
    "build": "npx eas-cli build --platform android --non-interactive --no-wait",
    "start": "expo start",
    "test": "jest --watchAll",
    "test:ci": "jest --coverage"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-native-fontawesome": "^1.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "expo": "~56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.13",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.6",
    "expo-haptics": "~56.0.3",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-navigation-bar": "~56.0.3",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-hook-form": "^7.77.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@christopherjbaker/eslint-config": "^3.1.4",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.0",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^#design/(.*)$": "<rootDir>/src/shared/design/$1/index.ts",
      "^#features/(.*)$": "<rootDir>/src/features/$1/index.ts",
      "^#i18n/(.*)$": "<rootDir>/src/shared/i18n/$1.ts",
      "^#shared/(.*)$": "<rootDir>/src/shared/$1/index.ts"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|react-native-gifted-charts|gifted-charts-core))",
      "/node_modules/react-native-reanimated/plugin/",
      "/node_modules/@react-native/babel-preset/"
    ]
  }
}
