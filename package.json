{
  "private": true,
  "name": "sito-wallet",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "type": "module",
  "imports": {
    "#design/*": "./src/shared/design/*/index.ts",
    "#shared/*": "./src/shared/*/index.ts"
  },
  "scripts": {
    "lint": "npm run lint-typecheck && npm run lint-eslint && npm run lint-prettier && npm run lint-knip",
    "lint:fix": "eslint --fix .",
    "lint-typecheck": "tsc --noEmit",
    "lint-eslint": "eslint .",
    "lint-prettier": "prettier --check .",
    "lint-knip": "knip",
    "prettier:format": "prettier --write .",
    "start": "expo start",
    "test": "jest --watchAll",
    "test:ci": "jest --coverage"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-native-fontawesome": "^1.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/drawer": "^7.10.3",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-hook-form": "^7.77.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@christopherjbaker/eslint-config": "^3.1.4",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^#design/(.*)$": "<rootDir>/src/shared/design/$1/index.ts",
      "^#shared/(.*)$": "<rootDir>/src/shared/$1/index.ts"
    }
  }
}
