# Wallet backend (Java API). Auth hits this by default — a closed/unreachable
# server makes login FAIL (it does not silently succeed).
#
# Host notes:
#   - iOS simulator:        http://localhost:8080
#   - Android emulator:     http://10.0.2.2:8080
#   - Physical device:      http://<your-LAN-IP>:8080
EXPO_PUBLIC_API_URL="http://localhost:8080"

# Opt-in mock auth for offline UI work (no backend). Logs in with fake data.
# Leave unset/false to use the real backend above.
# EXPO_PUBLIC_AUTH_MOCK="true"
